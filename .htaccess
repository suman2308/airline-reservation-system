# AeroBook – Security & Optimization

# Prevent directory browsing
Options -Indexes

# Protect configuration and SQL files
<FilesMatch "\.(php|sql|md)$">
    Order allow,deny
    Allow from all
</FilesMatch>

<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

<Files "functions.php">
    Order allow,deny
    Deny from all
</Files>

# Note: Above denies direct access but PHP can still include them.
# For some hosting, Deny from all might be too strict if used for includes.
# But usually, it works for public HTTP access.

# Set character encoding
AddDefaultCharset UTF-8

# Error handling
ErrorDocument 404 /airline-reservation-system/index.php
ErrorDocument 403 /airline-reservation-system/index.php

# Gzip compression (if available)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript
</IfModule>
